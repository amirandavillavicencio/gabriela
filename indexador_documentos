import os
import sys
import json
import fitz
from datetime import datetime

def limpiar(texto):
    if not texto:
        return ""
    texto = texto.replace("\x00", " ")
    texto = texto.replace("\r", "\n")
    return "\n".join([line.strip() for line in texto.splitlines() if line.strip()])

def procesar_pdf(pdf_path):
    doc = fitz.open(pdf_path)

    pages = []
    full = []

    for i, page in enumerate(doc, start=1):
        raw = page.get_text("text") or ""
        clean = limpiar(raw)
        has_text = bool(clean)

        pages.append({
            "page_number": i,
            "has_text": has_text,
            "text_source": "embedded_text" if has_text else "none",
            "raw_text": raw,
            "clean_text": clean
        })

        if clean:
            full.append(clean)

    doc.close()

    return {
        "id": f"doc_{int(datetime.now().timestamp())}",
        "source_name": os.path.basename(pdf_path),
        "page_count": len(pages),
        "created_at": datetime.now().isoformat(),
        "ocr_enabled": False,
        "pages": pages,
        "clean_full_text": "\n\n".join(full)
    }

def main():
    if len(sys.argv) < 2:
        print("Uso: python main.py archivo.pdf")
        return

    path = sys.argv[1]

    if not os.path.exists(path):
        print("Archivo no encontrado")
        return

    data = procesar_pdf(path)

    os.makedirs("salida", exist_ok=True)

    nombre = os.path.splitext(os.path.basename(path))[0]
    out = f"salida/{nombre}.json"

    with open(out, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

    print(f"Listo: {out}")

if __name__ == "__main__":
    main()
